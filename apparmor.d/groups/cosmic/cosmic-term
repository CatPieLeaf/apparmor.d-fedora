abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/cosmic-term
profile cosmic-term @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bus-session>
  include <abstractions/graphics>
  include <abstractions/nameservice-strict>

  @{exec_path} mr,

  # Terminal needs to exec shells and user programs
  @{bin}/@{shells} Ux,
  @{bin}/* Ux,

  /usr/share/cosmic/{,**} r,
  /usr/share/fonts/{,**} r,
  /usr/share/terminfo/{,**} r,

  owner @{HOME}/{,**} rw,
  owner @{HOME}/.config/cosmic/{,**} rw,
  owner @{user_share_dirs}/cosmic/{,**} rw,
  owner @{run}/user/@{uid}/wayland-* rw,

  owner @{PROC}/@{pid}/fd/ r,
  owner @{PROC}/@{pid}/mountinfo r,

  /dev/ptmx rw,
  /dev/pts/* rw,

  include if exists <local/cosmic-term>
}

# vim:syntax=apparmor
