abi <abi/4.0>,

include <tunables/global>

# rakuos-remove (rakuos-core, crates/pkgmgr/src/bin/remove.rs) — removes
# packages from the writable /usr overlay via dnf5.real, invoked from
# `rakupkg remove` (what dnf5's wrapper execs for `dnf5 remove`/`erase`).
@{exec_path} = /usr/libexec/rakuos/rakuos-remove
profile rakuos-remove @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>
  include <abstractions/nameservice-strict>

  capability chown,
  capability dac_override,
  capability dac_read_search,
  capability fowner,
  capability fsetid,
  capability sys_admin,

  @{exec_path} mr,

  @{bin}/dnf5.real rPx,
  @{bin}/mount     rPx,

  /etc/dnf/{,**} r,
  /usr/share/rakuos/{,**} r,

  /var/lib/rakuos/{,**} rwk,
  /var/lib/rakuos/overlay/upper/{,**} rwk,
  /var/lib/rakuos/overlay/work/{,**} rwk,
  /var/lib/rakuos/local-rpms/{,**} rwk,

  /run/rakuos-overlay.lock rwk,

  @{PROC}/@{pid}/mounts r,
  @{PROC}/mounts r,

  include if exists <local/rakuos-remove>
}

# vim:syntax=apparmor
