abi <abi/4.0>,

include <tunables/global>

# rakuos-webapp-launcher (rakuos-software, resources/rakuos-webapp-launcher)
# — trivial wrapper: exec's the real libexec launcher with all args passed
# through, no logic of its own.
@{exec_path} = /usr/bin/rakuos-webapp-launcher
profile rakuos-webapp-launcher @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>

  @{exec_path} r,

  @{bin}/rakuos-webapp-launcher-electron rPx,

  @{PROC}/@{pid}/cmdline r,

  include if exists <local/rakuos-webapp-launcher>
}

# vim:syntax=apparmor
