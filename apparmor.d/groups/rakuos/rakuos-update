abi <abi/4.0>,

include <tunables/global>

# rakuos-update (rakuos-core, crates/pkgmgr/src/bin/update.rs) — checks/applies
# package, flatpak, and system-image updates. Talks to quay.io over HTTPS to
# check image tags, shells out to dnf5.real/flatpak/bootc, and drops into
# per-user sessions via runuser to check/upgrade user flatpaks.
@{exec_path} = /usr/libexec/rakuos/rakuos-update
profile rakuos-update @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>
  include <abstractions/nameservice-strict>
  include <abstractions/openssl.d>
  include <abstractions/ssl_certs.d>

  capability chown,
  capability dac_override,
  capability dac_read_search,
  capability fowner,
  capability fsetid,
  capability sys_admin,
  capability setuid,
  capability setgid,

  network inet stream,
  network inet6 stream,

  @{exec_path} mr,

  @{bin}/dnf5.real rPx,
  @{bin}/mount     rPx,
  @{bin}/flatpak   rPx,
  @{bin}/bootc     rPx,
  @{bin}/fc-cache  rPx,
  @{bin}/runuser   rPx,
  @{bin}/id        rix,

  /etc/dnf/{,**} r,
  /usr/share/rakuos/{,**} r,
  /etc/pki/ca-trust/{,**} r,
  /usr/share/crypto-policies/{,**} r,

  /var/lib/rakuos/{,**} rwk,
  /var/lib/rakuos/overlay/upper/{,**} rwk,
  /var/lib/rakuos/overlay/work/{,**} rwk,

  /run/rakuos-overlay.lock rwk,

  @{PROC}/@{pid}/mounts r,
  @{PROC}/mounts r,
  @{PROC}/cmdline r,

  include if exists <local/rakuos-update>
}

# vim:syntax=apparmor
