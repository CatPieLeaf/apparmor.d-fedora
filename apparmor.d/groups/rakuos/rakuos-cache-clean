abi <abi/4.0>,

include <tunables/global>

# rakuos-cache-clean (rakuos-core, crates/pkgmgr/src/bin/cache_clean.rs) —
# prunes stale/uninstalled RPMs out of the dnf5 and local-rpm caches by
# cross-checking against the overlay RPM db.
@{exec_path} = /usr/libexec/rakuos/rakuos-cache-clean
profile rakuos-cache-clean @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>

  capability dac_read_search,

  @{exec_path} mr,

  @{bin}/rpm rPx,

  /var/lib/rakuos/{,**} rw,
  /var/lib/rakuos/local-rpms/{,**} rw,
  /var/lib/rakuos/overlay/upper/share/rpm/{,**} r,
  /var/cache/libdnf5/{,**} rw,

  include if exists <local/rakuos-cache-clean>
}

# vim:syntax=apparmor
