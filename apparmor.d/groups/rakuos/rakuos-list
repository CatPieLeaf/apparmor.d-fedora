abi <abi/4.0>,

include <tunables/global>

# rakuos-list (rakuos-core, crates/pkgmgr/src/bin/list.rs) — prints the
# RakuOS overlay package lists. Pure read-only, no subprocess execs.
@{exec_path} = /usr/libexec/rakuos/rakuos-list
profile rakuos-list @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  @{exec_path} mr,

  /var/lib/rakuos/packages.list r,
  /var/lib/rakuos/packages-rpm.list r,

  include if exists <local/rakuos-list>
}

# vim:syntax=apparmor
