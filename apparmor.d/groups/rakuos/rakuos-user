abi <abi/4.0>,

include <tunables/global>

# rakuos-user (rakuos-core, crates/pkgmgr/src/bin/user.rs) — per-user session
# setup, run unprivileged from the rakuos-user.service systemd *user* unit.
# Syncs GTK themes into the user's home, manages GTK theme/dark-light state,
# sets the default shell to fish on first run, and dispatches queued
# notifications. Unlike the other rakuos-core binaries this one never runs as
# root, so it is confined to the invoking user's own files.
@{exec_path} = /usr/libexec/rakuos/rakuos-user
profile rakuos-user @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>
  include <abstractions/nameservice-strict>

  @{exec_path} mr,

  @{bin}/gsettings   rPx,
  @{bin}/rsync       rPx,
  @{bin}/chown       rPx,
  @{bin}/chsh        rPx,
  @{bin}/getent      rix,
  @{bin}/notify-send rPx,
  @{bin}/id          rix,
  @{sh_path}         rix,
  @{bin}/inotifywait rPx,

  /usr/share/themes/{,**} r,
  /usr/share/cosmic/{,**} r,
  /usr/share/plasma/plasmoids/{,**} r,
  /etc/fish/conf.d/rakuos-aliases.fish r,

  owner @{HOME}/ r,
  owner @{HOME}/.icons/ rw,
  owner @{HOME}/.themes/{,**} rwk,
  owner @{user_config_dirs}/rakuos/{,**} rwk,
  owner @{user_config_dirs}/gtk-3.0/{,**} rwk,
  owner @{user_config_dirs}/gtk-4.0/{,**} rwk,
  owner @{user_config_dirs}/kdeglobals r,
  owner @{user_config_dirs}/kwalletrc rw,
  owner @{user_config_dirs}/cosmic/com.system76.CosmicAppList/v1/favorites rw,
  owner @{user_share_dirs}/icons/ rw,
  owner @{user_share_dirs}/flatpak/overrides/global rw,

  /var/lib/rakuos/update-notify.pending r,
  /var/lib/rakuos/update-notify.pending w,
  /var/lib/rakuos/image-update.marker r,
  owner /tmp/rakuos-overlay-update.ready rw,

  @{PROC}/cmdline r,
  @{PROC}/@{pid}/status r,

  signal (send) set=(term) peer=rakuos-user,

  include if exists <local/rakuos-user>
}

# vim:syntax=apparmor
