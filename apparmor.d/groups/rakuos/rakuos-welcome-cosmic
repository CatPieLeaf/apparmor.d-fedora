abi <abi/4.0>,

include <tunables/global>

# rakuos-welcome-cosmic (rakuos-welcome, crates/welcome-cosmic + shared
# welcome-setup/appstream/geonames crates) — libcosmic/iced first-login
# wizard; all i18n/theme-preview/city data compiled into the binary. Same
# pkexec/sudo-rs privilege model as the other frontends. Also copies bundled
# cosmic layout/theme configs into the user's ~/.config/cosmic and can
# restart cosmic-panel/cosmic-randr to apply layout changes during setup.
@{exec_path} = /usr/libexec/rakuos/rakuos-welcome-cosmic
profile rakuos-welcome-cosmic @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>
  include <abstractions/nameservice-strict>
  include <abstractions/fonts-strict>
  include <abstractions/freedesktop.org.d>

  @{exec_path} mr,

  @{bin}/locale     rix,
  @{bin}/pkexec     rCx -> pkexec,
  @{bin}/sudo-rs    rCx -> sudo,
  @{bin}/nmcli      rPx,
  @{bin}/xdg-open   rPx,
  @{bin}/killall    rPx,
  @{bin}/cosmic-randr rPx,

  /usr/share/rakuos-welcome/{,**} r,
  /usr/share/rakuos/appstream/{,**} r,
  /usr/share/cosmic-layouts/{,**} r,
  /usr/share/cosmic-themes/{,**} r,
  /usr/share/swcatalog/xml/{,**} r,
  /usr/share/app-info/xmls/{,**} r,
  /var/cache/app-info/xmls/{,**} r,
  /usr/share/metainfo/{,**} r,
  /usr/share/appdata/{,**} r,
  /var/lib/flatpak/appstream/{,**} r,
  /var/lib/flatpak/app/{,**} r,
  /usr/share/icons/hicolor/{,**} r,
  /usr/share/pixmaps/{,**} r,
  /etc/os-release r,

  owner @{HOME}/.local/share/flatpak/appstream/{,**} r,
  owner @{user_config_dirs}/rakuos/welcome-done rw,
  owner @{user_config_dirs}/cosmic/{,**} rw,

  @{PROC}/@{pid}/cmdline r,
  @{PROC}/@{pid}/status r,

  profile pkexec {
    include <abstractions/base>
    include <abstractions/app/pkexec>

    include if exists <local/rakuos-welcome-cosmic_pkexec>
  }

  profile sudo {
    include <abstractions/base>
    include <abstractions/authentication.d>
    include <abstractions/nameservice-strict>

    capability setuid,
    capability setgid,

    @{bin}/sudo-rs mr,
    @{bin}/bootc          rPx,
    @{bin}/rakuos-install rPx,
    @{bin}/rakuos-remove  rPx,

    include if exists <local/rakuos-welcome-cosmic_sudo>
  }

  include if exists <local/rakuos-welcome-cosmic>
}

# vim:syntax=apparmor
