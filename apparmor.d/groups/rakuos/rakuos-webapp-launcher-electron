abi <abi/4.0>,

include <tunables/global>

# rakuos-webapp-launcher (libexec) (rakuos-software,
# resources/rakuos-webapp-launcher-libexec) — parses --url/--name/
# --session-group/--file/--app-id, reads the per-webapp JSON config and icon
# from ~/.local/share/rakuos/webapps, then execs castlabs Electron (with
# Widevine CDM) pointed at the bundled Electron web-app shim. Falls back to
# notify-send if the Electron binary is missing.
@{exec_path} = /usr/libexec/rakuos/software/rakuos-webapp-launcher
profile rakuos-webapp-launcher-electron @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>
  include <abstractions/nameservice-strict>
  include <abstractions/freedesktop.org.d>

  @{exec_path} r,

  @{bin}/notify-send rPx,
  /usr/lib/rakuos-electron/electron rPx,

  /usr/lib/rakuos-electron/{,**} r,
  /usr/lib/rakuos-electron-webapp/{,**} r,

  owner @{HOME}/.local/share/rakuos/webapps/{,**} r,

  @{PROC}/@{pid}/cmdline r,

  include if exists <local/rakuos-webapp-launcher-electron>
}

# vim:syntax=apparmor
