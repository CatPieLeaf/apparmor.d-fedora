abi <abi/4.0>,

include <tunables/global>

# rakuos-updater (rakuos-core, crates/pkgmgr/src/bin/updater.rs) — checks/
# applies system-image updates only (a slimmer sibling of rakuos-update's
# image-update path, used by background update-check timers).
@{exec_path} = /usr/libexec/rakuos/rakuos-updater
profile rakuos-updater @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>
  include <abstractions/bash-strict>
  include <abstractions/nameservice-strict>
  include <abstractions/openssl.d>
  include <abstractions/ssl_certs.d>

  capability sys_admin,

  network inet stream,
  network inet6 stream,

  @{exec_path} mr,

  @{bin}/bootc     rPx,
  @{bin}/fc-cache  rPx,

  /etc/pki/ca-trust/{,**} r,
  /usr/share/crypto-policies/{,**} r,

  /var/lib/rakuos/{,**} rwk,

  include if exists <local/rakuos-updater>
}

# vim:syntax=apparmor
