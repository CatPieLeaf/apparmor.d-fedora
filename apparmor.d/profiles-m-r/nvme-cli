abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/nvme
profile nvme-cli @{exec_path} flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/base>

  capability sys_admin sys_rawio,

  @{exec_path} mr,

  /dev/nvme{,*} rw,

  @{sys}/class/nvme/{,**} r,
  @{sys}/devices/**/nvme/{,**} r,

  @{PROC}/mounts r,

  include if exists <local/nvme-cli>
}

# vim:syntax=apparmor
